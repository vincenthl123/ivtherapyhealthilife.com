{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/book",
      "destination": "https://healthilife.fillout.com/book",
      "permanent": false
    },
    {
      "source": "/book/:path*",
      "destination": "https://healthilife.fillout.com/book/:path*",
      "permanent": false
    }
  ]
}